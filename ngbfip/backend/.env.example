# NG-BIFP Backend Environment Configuration

# Application Settings
APP_NAME=NG-BIFP Fraud Detection
DEBUG=False
VERSION=1.0.0

# Database Configuration
DATABASE_URL=postgresql://bifp_user:bifp_password@postgres:5432/ng_bifp
SQLALCHEMY_ECHO=False

# Security Configuration
SECRET_KEY=change-this-to-a-random-32-character-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ML Configuration
ML_MODEL_PATH=models/
FRAUD_DETECTION_CONTAMINATION=0.1

# API Configuration
API_TITLE=NG-BIFP Fraud Detection API
API_DESCRIPTION=Next-Generation Bank Integrated Fraud Prevention
API_VERSION=1.0.0

# Feature Flags
ENABLE_AUDIT_LOGGING=True
ENABLE_ML_INFERENCE=True
ENABLE_NOTIFICATIONS=True
