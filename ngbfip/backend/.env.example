# NG-BIFP Backend Environment

# Application Settings
APP_NAME=NG-BIFP Fraud Detection
DEBUG=False
VERSION=1.0.0

# Database Configuration (Update these for production)
DATABASE_URL=postgresql://bifp_user:bifp_password@postgres:5432/ng_bifp
SQLALCHEMY_ECHO=False

# Security Configuration
SECRET_KEY=your-super-secret-key-change-this-in-production-to-random-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
